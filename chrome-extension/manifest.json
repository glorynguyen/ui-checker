{
  "manifest_version": 3,
  "name": "Figma CSS Diff",
  "version": "1.0.0",
  "description": "Compare rendered browser styles against Figma Dev Mode CSS specs to catch spacing, typography, and color discrepancies.",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "devtools_page": "devtools/devtools.html",
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["activeTab"]
}
